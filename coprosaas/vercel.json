{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mon-syndic-benevole.fr" }],
      "destination": "https://www.mon-syndic-benevole.fr/:path*",
      "statusCode": 301
    }
  ],
  "crons": [
    {
      "path": "/api/cron/rappels-appels",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/rappels-ag",
      "schedule": "15 8 * * *"
    },
    {
      "path": "/api/cron/stripe-sync",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/purge-user-events",
      "schedule": "0 2 1 * *"
    }
  ]
}
